<Window x:Class="BO1Tracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Black Ops Tracker"
        Width="860" Height="700"
        MinWidth="640" MinHeight="520"
        Background="{StaticResource BrushBgMain}"
        FontFamily="Segoe UI"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
            <Setter Property="Margin"     Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />   <!-- 0  Header + sep -->
        <RowDefinition Height="*" />      <!-- 1  Content panels -->
    </Grid.RowDefinitions>

    <!-- ══ HEADER PARTAGÉ ══ -->
    <Grid Grid.Row="0" Margin="24,20,24,4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="BLACK OPS TRACKER"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           VerticalAlignment="Center" />
                <!-- Sélecteur BO1 / BO2 -->
                <Border Background="{StaticResource BrushBgCard}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1" CornerRadius="6"
                        Margin="14,0,0,0" Padding="3"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="Bo1TabButton"
                                      Content="BO1"
                                      IsChecked="True"
                                      FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                      Padding="14,5"
                                      Background="{StaticResource BrushAccentDark}"
                                      Foreground="{StaticResource BrushAccentLight}"
                                      BorderBrush="{StaticResource BrushAccent}"
                                      BorderThickness="1"
                                      Cursor="Hand"
                                      Click="Bo1TabButton_Click" />
                        <ToggleButton x:Name="Bo2TabButton"
                                      Content="BO2"
                                      IsChecked="False"
                                      FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                      Padding="14,5"
                                      Margin="4,0,0,0"
                                      Background="{StaticResource BrushBgCard}"
                                      Foreground="{StaticResource BrushTextSecondary}"
                                      BorderBrush="{StaticResource BrushBorder}"
                                      BorderThickness="1"
                                      Cursor="Hand"
                                      Click="Bo2TabButton_Click" />
                        <ToggleButton x:Name="MultiTabButton"
                                      Content="MULTI"
                                      IsChecked="False"
                                      FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                      Padding="14,5"
                                      Margin="4,0,0,0"
                                      Background="{StaticResource BrushBgCard}"
                                      Foreground="{StaticResource BrushTextSecondary}"
                                      BorderBrush="{StaticResource BrushBorder}"
                                      BorderThickness="1"
                                      Cursor="Hand"
                                      Click="MultiTabButton_Click" />
                        <ToggleButton x:Name="TwitchTabButton"
                                      Content="TWITCH"
                                      IsChecked="False"
                                      FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                      Padding="14,5"
                                      Margin="4,0,0,0"
                                      Background="{StaticResource BrushBgCard}"
                                      Foreground="{StaticResource BrushTextSecondary}"
                                      BorderBrush="{StaticResource BrushBorder}"
                                      BorderThickness="1"
                                      Cursor="Hand"
                                      Click="TwitchTabButton_Click" />
                    </StackPanel>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="ExportTxtButton"
                        Content="&#x1F4C4; ENREGISTRER"
                        VerticalAlignment="Center"
                        FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                        Padding="14,8"
                        Margin="0,0,8,0"
                        Background="{StaticResource BrushAccentDark}"
                        Foreground="{StaticResource BrushAccentLight}"
                        BorderBrush="{StaticResource BrushAccent}"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="ExportTxtButton_Click" />
                <Button x:Name="ResetAllButton"
                        Content="&#x1F5D1; TOUT EFFACER"
                        VerticalAlignment="Center"
                        FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                        Padding="14,8"
                        Background="#3D1010"
                        Foreground="#FF6B6B"
                        BorderBrush="#C0392B"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="ResetAllButton_Click" />
            </StackPanel>
        </Grid>
        <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}" Margin="0,0,0,0" />
    </Grid>

    <!-- ══ CONTENU BO1 ══ -->
    <ScrollViewer x:Name="Bo1Panel" Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <Grid Margin="24,10,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- 0  Label map -->
            <RowDefinition Height="Auto" />   <!-- 1  Boutons maps -->

            <!-- ── MANCHES SPÉCIALES ── -->
            <RowDefinition Height="Auto" />   <!-- 2  Sep spéciale -->
            <RowDefinition Height="Auto" />   <!-- 3  Label spéciale -->
            <RowDefinition Height="Auto" />   <!-- 4  Contrôles spéciale -->
            <RowDefinition Height="Auto" />   <!-- 5  Historique spéciale -->

            <RowDefinition Height="Auto" />   <!-- 6  Sep options -->
            <RowDefinition Height="Auto" />   <!-- 7  Label toggle bonus -->
            <RowDefinition Height="Auto" />   <!-- 8  Toggle buttons -->

            <!-- ── TRACKER BOÎTE ── -->
            <RowDefinition Height="Auto" />   <!-- 9  Sep boîte -->
            <RowDefinition Height="Auto" />   <!-- 10 Titre map + labels boîte -->
            <RowDefinition Height="Auto" />   <!-- 11 Box locations panel -->
            <RowDefinition Height="Auto" />   <!-- 12 Reset buttons boîte -->
            <RowDefinition Height="Auto" />   <!-- 13 Historique boîte -->

            <!-- ── TRACKER BONUS ── -->
            <RowDefinition Height="Auto" />   <!-- 14 Sep bonus -->
            <RowDefinition Height="Auto" />   <!-- 15 Labels bonus -->
            <RowDefinition Height="Auto" />   <!-- 16 Drops panel -->
            <RowDefinition Height="Auto" />   <!-- 17 Reset buttons bonus -->
            <RowDefinition Height="Auto" />   <!-- 18 Historique bonus -->
        </Grid.RowDefinitions>

        <!-- En-tête CHOIX DE LA MAP cliquable -->
        <Grid Grid.Row="0" Margin="0,0,0,8" Cursor="Hand"
              MouseLeftButtonUp="MapHeader_Click">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="CHOIX DE LA MAP"
                           FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" />
                <!-- Map sélectionnée inline (visible quand collapsed) -->
                <Border x:Name="MapSelectedInline"
                        Margin="10,0,0,0" Padding="8,2"
                        CornerRadius="4"
                        Background="{StaticResource BrushAccentDark}"
                        BorderBrush="{StaticResource BrushAccent}" BorderThickness="1"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="MapSelectedInlineText"
                               FontFamily="Consolas" FontSize="10"
                               Foreground="{StaticResource BrushAccentLight}" />
                </Border>
            </StackPanel>
            <TextBlock x:Name="MapChevron"
                       Text="▼"
                       FontFamily="Consolas" FontSize="10"
                       Foreground="{StaticResource BrushTextMuted}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Boutons maps (pliable) -->
        <WrapPanel x:Name="MapButtonsPanel" Grid.Row="1"
                   Orientation="Horizontal" Margin="0,0,0,16" />

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- MANCHES SPÉCIALES                                           -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- Séparateur manches spéciales -->
        <Rectangle Grid.Row="2" Fill="{StaticResource BrushBorder}" Margin="0,0,0,16" />

        <!-- Label manches spéciales -->
        <TextBlock Grid.Row="3" Text="MANCHES SPÉCIALES"
                   Style="{StaticResource SectionLabelStyle}" />

        <!-- Contrôles manches spéciales -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Première manche :"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource BrushTextSecondary}"
                           FontFamily="Consolas" FontSize="13"
                           Margin="0,0,10,0" />
                <TextBox x:Name="DogRoundInput"
                         Width="60" Height="32"
                         FontFamily="Consolas" FontSize="14"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         Background="{StaticResource BrushBgCard}"
                         Foreground="{StaticResource BrushTextPrimary}"
                         BorderBrush="{StaticResource BrushBorder}"
                         BorderThickness="1"
                         Margin="0,0,10,0"
                         MaxLength="3"
                         PreviewTextInput="DogRoundInput_PreviewTextInput" />
                <Button x:Name="SetDogRoundButton"
                        Content="ENREGISTRER"
                        Style="{StaticResource ResetButtonStyle}"
                        Margin="0,0,10,0"
                        Click="SetDogRoundButton_Click" />
                <Button x:Name="ResetDogRoundsButton"
                        Content="EFFACER"
                        Style="{StaticResource ResetDangerButtonStyle}"
                        Click="ResetDogRoundsButton_Click" />
            </StackPanel>

            <StackPanel x:Name="DogNextRoundPanel" Orientation="Horizontal"
                        Visibility="Collapsed" Margin="0,0,0,0">
                <TextBlock Text="Prochaine manche :"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource BrushTextSecondary}"
                           FontFamily="Consolas" FontSize="13"
                           Margin="0,0,10,0" />
                <Border x:Name="DogNext4Badge"
                        Background="{StaticResource BrushAccentDark}"
                        BorderBrush="{StaticResource BrushAccent}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="12,6" Margin="0,0,8,0"
                        Cursor="Hand"
                        MouseLeftButtonUp="DogNext4Badge_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+4 → " FontFamily="Consolas" FontSize="13"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="DogNext4Text"
                                   FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource BrushAccentLight}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border x:Name="DogNext5Badge"
                        Background="{StaticResource BrushAccentDark}"
                        BorderBrush="{StaticResource BrushAccent}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="12,6" Margin="0,0,0,0"
                        Cursor="Hand"
                        MouseLeftButtonUp="DogNext5Badge_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+5 → " FontFamily="Consolas" FontSize="13"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="DogNext5Text"
                                   FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource BrushAccentLight}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- Historique manches spéciales -->
        <Border x:Name="DogHistoryBox"
                Grid.Row="5"
                Background="{StaticResource BrushBgHistory}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,14" Margin="0,0,0,24"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="HISTORIQUE DES MANCHES SPÉCIALES"
                           Style="{StaticResource SectionLabelStyle}" />
                <WrapPanel x:Name="DogHistoryPanel" Orientation="Horizontal" />
            </StackPanel>
        </Border>

        <!-- Séparateur options -->
        <Rectangle Grid.Row="6" Fill="{StaticResource BrushBorder}" Margin="0,0,0,16" />

        <!-- Label toggle bonus -->
        <TextBlock Grid.Row="7" Text="ACTIVER / DESACTIVER DES BONUS"
                   Style="{StaticResource SectionLabelStyle}" />

        <!-- Boutons toggle bonus -->
        <WrapPanel x:Name="ToggleButtonsPanel" Grid.Row="8"
                   Orientation="Horizontal" Margin="0,0,0,20" />

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TRACKER CYCLE DE BOÎTE                                      -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <Rectangle x:Name="BoxSeparator" Grid.Row="9"
                   Fill="{StaticResource BrushBorder}"
                   Margin="0,0,0,16" Visibility="Collapsed" />

        <StackPanel x:Name="BoxLabelPanel" Grid.Row="10"
                    Margin="0,0,0,12" Visibility="Collapsed">
            <DockPanel Margin="0,0,0,6">
                <TextBlock x:Name="MapTitleText"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           VerticalAlignment="Center"/>
                <Button x:Name="OverlayButton"
                        DockPanel.Dock="Right"
                        Content="📺  OVERLAY OBS"
                        Style="{StaticResource ResetButtonStyle}"
                        HorizontalAlignment="Right"
                        Click="OverlayButton_Click"
                        ToolTip="Ouvre une fenêtre transparente à capturer dans OBS (Window Capture)"/>
            </DockPanel>
            <TextBlock Text="TRACKER CYCLE DE BOÎTE"
                       Style="{StaticResource SectionLabelStyle}" Margin="0" />
            <TextBlock Text="CLIQUE SUR LES EMPLACEMENTS AU FUR ET À MESURE QUE LA BOÎTE SE DÉPLACE"
                       Style="{StaticResource SectionLabelStyle}" Margin="0" />
        </StackPanel>

        <WrapPanel x:Name="BoxLocationsPanel" Grid.Row="11"
                   Orientation="Horizontal"
                   Margin="0,0,0,16" Visibility="Collapsed" />

        <StackPanel x:Name="BoxResetButtonsPanel" Grid.Row="12"
                    Orientation="Horizontal"
                    Margin="0,0,0,20" Visibility="Collapsed">
            <Button x:Name="ResetBoxCycleButton"
                    Content="REINITIALISER LE CYCLE BOÎTE"
                    Style="{StaticResource ResetButtonStyle}"
                    Margin="0,0,10,0"
                    Click="ResetBoxCycleButton_Click" />
            <Button x:Name="ResetBoxHistoryButton"
                    Content="EFFACER L'HISTORIQUE BOÎTE"
                    Style="{StaticResource ResetDangerButtonStyle}"
                    Click="ResetBoxHistoryButton_Click" />
        </StackPanel>

        <Border x:Name="BoxHistoryBox"
                Grid.Row="13"
                Background="{StaticResource BrushBgHistory}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,14" Margin="0,0,0,24"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="HISTORIQUE DES CYCLES BOÎTE"
                           Style="{StaticResource SectionLabelStyle}" />
                <StackPanel x:Name="BoxHistoryPanel" />
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TRACKER CYCLE DE BONUS                                       -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <Rectangle x:Name="BonusSeparator" Grid.Row="14"
                   Fill="{StaticResource BrushBorder}"
                   Margin="0,0,0,16" Visibility="Collapsed" />

        <StackPanel x:Name="BonusLabelPanel" Grid.Row="15"
                    Margin="0,0,0,12" Visibility="Collapsed">
            <DockPanel Margin="0,0,0,6">
                <TextBlock Text="TRACKER CYCLE DE BONUS"
                           Style="{StaticResource SectionLabelStyle}" Margin="0" VerticalAlignment="Center"/>
                <Button x:Name="OverlayBonusButton"
                        DockPanel.Dock="Right"
                        Content="📺  OVERLAY OBS"
                        Style="{StaticResource ResetButtonStyle}"
                        HorizontalAlignment="Right"
                        Click="OverlayBonusButton_Click"
                        ToolTip="Ouvre l'overlay OBS en mode Bonus BO1"/>
            </DockPanel>
            <TextBlock Text="CLIQUE SUR LES BONUS AU FUR ET À MESURE QU'ILS TOMBENT"
                       Style="{StaticResource SectionLabelStyle}" Margin="0" />
        </StackPanel>

        <WrapPanel x:Name="DropsPanel" Grid.Row="16"
                   Orientation="Horizontal"
                   Margin="0,0,0,16" Visibility="Collapsed" />

        <StackPanel x:Name="ResetButtonsPanel" Grid.Row="17"
                    Orientation="Horizontal"
                    Margin="0,0,0,20" Visibility="Collapsed">
            <Button x:Name="ResetCycleButton"
                    Content="REINITIALISER LE CYCLE BONUS"
                    Style="{StaticResource ResetButtonStyle}"
                    Margin="0,0,10,0"
                    Click="ResetCycleButton_Click" />
            <Button x:Name="ResetHistoryButton"
                    Content="EFFACER L'HISTORIQUE BONUS"
                    Style="{StaticResource ResetDangerButtonStyle}"
                    Click="ResetHistoryButton_Click" />
        </StackPanel>

        <Border x:Name="HistoryBox"
                Grid.Row="18"
                Background="{StaticResource BrushBgHistory}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,14" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="HISTORIQUE DES CYCLES BONUS"
                           Style="{StaticResource SectionLabelStyle}" />
                <StackPanel x:Name="HistoryPanel" />
            </StackPanel>
        </Border>

      </Grid>
    </ScrollViewer>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- PANNEAU BO2                                                    -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <ScrollViewer x:Name="Bo2Panel" Grid.Row="1" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
      <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- 0  Label map BO2 -->
            <RowDefinition Height="Auto" />   <!-- 1  Boutons maps BO2 -->
            <!-- ── TOGGLE BONUS BO2 ── -->
            <RowDefinition Height="Auto" />   <!-- 2  Sep options -->
            <RowDefinition Height="Auto" />   <!-- 3  Label toggle bonus -->
            <RowDefinition Height="Auto" />   <!-- 4  Toggle buttons -->
            <!-- ── TRACKER BONUS BO2 ── -->
            <RowDefinition Height="Auto" />   <!-- 5  Sep bonus -->
            <RowDefinition Height="Auto" />   <!-- 6  Labels bonus -->
            <RowDefinition Height="Auto" />   <!-- 7  Drops panel -->
            <RowDefinition Height="Auto" />   <!-- 8  Reset buttons bonus -->
            <RowDefinition Height="Auto" />   <!-- 9  Historique bonus -->
        </Grid.RowDefinitions>

        <!-- En-tête CHOIX DE LA MAP BO2 -->
        <TextBlock Grid.Row="0" Text="CHOIX DE LA MAP — BLACK OPS 2"
                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                   Foreground="{StaticResource BrushTextMuted}"
                   Margin="0,0,0,10" />

        <!-- Boutons maps BO2 -->
        <WrapPanel x:Name="Bo2MapButtonsPanel" Grid.Row="1"
                   Orientation="Horizontal" Margin="0,0,0,16" />

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ACTIVER / DÉSACTIVER DES BONUS BO2                         -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- Séparateur options -->
        <Rectangle Grid.Row="2" Fill="{StaticResource BrushBorder}" Margin="0,0,0,16" />

        <!-- Label toggle bonus -->
        <TextBlock Grid.Row="3" Text="ACTIVER / DESACTIVER DES BONUS"
                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                   Foreground="{StaticResource BrushTextMuted}"
                   Margin="0,0,0,10" />

        <!-- Boutons toggle bonus BO2 -->
        <WrapPanel x:Name="Bo2ToggleButtonsPanel" Grid.Row="4"
                   Orientation="Horizontal" Margin="0,0,0,20" />

        <!-- ══ TRACKER BONUS BO2 ══ -->
        <Rectangle x:Name="Bo2BonusSeparator" Grid.Row="5"
                   Fill="{StaticResource BrushBorder}"
                   Margin="0,0,0,16" Visibility="Collapsed" />

        <StackPanel x:Name="Bo2BonusLabelPanel" Grid.Row="6"
                    Margin="0,0,0,12" Visibility="Collapsed">
            <DockPanel Margin="0,0,0,6">
                <TextBlock x:Name="Bo2MapTitleText"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           VerticalAlignment="Center"/>
                <Button x:Name="OverlayBo2Button"
                        DockPanel.Dock="Right"
                        Content="📺  OVERLAY OBS"
                        Style="{StaticResource ResetButtonStyle}"
                        HorizontalAlignment="Right"
                        Click="OverlayBo2Button_Click"
                        ToolTip="Ouvre l'overlay OBS en mode Bonus BO2"/>
            </DockPanel>
            <TextBlock Text="TRACKER CYCLE DE BONUS"
                       FontFamily="Consolas" FontSize="11"
                       Foreground="{StaticResource BrushTextMuted}"
                       Margin="0" />
            <TextBlock Text="CLIQUE SUR LES BONUS AU FUR ET À MESURE QU'ILS TOMBENT"
                       FontFamily="Consolas" FontSize="11"
                       Foreground="{StaticResource BrushTextMuted}"
                       Margin="0" />
        </StackPanel>

        <WrapPanel x:Name="Bo2DropsPanel" Grid.Row="7"
                   Orientation="Horizontal"
                   Margin="0,0,0,16" Visibility="Collapsed" />

        <StackPanel x:Name="Bo2ResetButtonsPanel" Grid.Row="8"
                    Orientation="Horizontal"
                    Margin="0,0,0,20" Visibility="Collapsed">
            <Button x:Name="Bo2ResetCycleButton"
                    Content="REINITIALISER LE CYCLE BONUS"
                    Style="{StaticResource ResetButtonStyle}"
                    Margin="0,0,10,0"
                    Click="Bo2ResetCycleButton_Click" />
            <Button x:Name="Bo2ResetHistoryButton"
                    Content="EFFACER L'HISTORIQUE BONUS"
                    Style="{StaticResource ResetDangerButtonStyle}"
                    Click="Bo2ResetHistoryButton_Click" />
        </StackPanel>

        <Border x:Name="Bo2HistoryBox"
                Grid.Row="9"
                Background="{StaticResource BrushBgHistory}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,14" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="HISTORIQUE DES CYCLES BONUS"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource BrushTextMuted}"
                           Margin="0,0,0,10" />
                <StackPanel x:Name="Bo2HistoryPanel" />
            </StackPanel>
        </Border>

      </Grid>
    </ScrollViewer>

    <!-- ══ CONTENU MULTI ══ -->
    <ScrollViewer x:Name="MultiPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
      <Grid Margin="24,10,24,20">

        <!-- PANNEAU MULTIJOUEUR -->
        <Border x:Name="MultiPanelBorder"
                Background="#0D1B14"
                BorderBrush="#1D9E75"
                BorderThickness="1" CornerRadius="10"
                Margin="0,0,0,10">
            <StackPanel>
                <!-- En-tête -->
                <Border Padding="16,12" CornerRadius="10">
                    <TextBlock Text="🌐 MULTIJOUEUR (Radmin VPN / Hamachi)"
                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                               Foreground="#1D9E75" VerticalAlignment="Center" />
                </Border>

                <!-- Contenu -->
                <StackPanel x:Name="MultiContent" Margin="16,0,16,14">

                <!-- Statut de connexion -->
                <Border x:Name="MultiStatusBorder"
                        Background="#0A110D"
                        BorderBrush="#1D3A28"
                        BorderThickness="1" CornerRadius="6"
                        Padding="12,8" Margin="0,0,0,12">
                    <TextBlock x:Name="MultiStatusText"
                               Text="⚫  Hors ligne — choisissez un mode ci-dessous"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="#6B8C7A" />
                </Border>

                <!-- Pseudo du joueur -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="TON PSEUDO  " FontFamily="Consolas" FontSize="11"
                               FontWeight="Bold" Foreground="#6BAA88"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="PlayerNameBox"
                             Width="160" Height="28"
                             Text=""
                             FontFamily="Consolas" FontSize="12"
                             VerticalContentAlignment="Center"
                             Background="#0D1B14" Foreground="#A8D5BF"
                             BorderBrush="#1D3A28" BorderThickness="1"
                             MaxLength="24" />
                </StackPanel>

                <!-- Liste joueurs connectés (visible hôte uniquement) -->
                <Border x:Name="PlayersListBorder"
                        Background="#0A110D" BorderBrush="#1D3A28"
                        BorderThickness="1" CornerRadius="6"
                        Padding="12,8" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="JOUEURS CONNECTÉS" FontFamily="Consolas" FontSize="10"
                                   FontWeight="Bold" Foreground="#1D9E75" Margin="0,0,0,6" />
                        <StackPanel x:Name="PlayersListPanel" />
                    </StackPanel>
                </Border>

                <!-- Ligne de contrôles -->
                <StackPanel Orientation="Horizontal">

                    <!-- HÔTE -->
                    <Border Background="#0A1F16" BorderBrush="#1D9E75" BorderThickness="1"
                            CornerRadius="8" Padding="12,10" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="MOI = HÔTE" FontFamily="Consolas" FontSize="10"
                                       FontWeight="Bold" Foreground="#1D9E75" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="HostPortBox"
                                         Width="60" Height="28"
                                         Text="5757"
                                         FontFamily="Consolas" FontSize="12"
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         Background="#0D1B14" Foreground="#A8D5BF"
                                         BorderBrush="#1D3A28" BorderThickness="1"
                                         Margin="0,0,8,0" />
                                <Button x:Name="StartHostButton"
                                        Content="HÉBERGER"
                                        FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                        Padding="12,6"
                                        Background="#1A4A30" Foreground="#A8D5BF"
                                        BorderBrush="#1D9E75" BorderThickness="1"
                                        Cursor="Hand"
                                        Click="StartHostButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- REJOINDRE -->
                    <Border Background="#0A1F16" BorderBrush="#2D5A40" BorderThickness="1"
                            CornerRadius="8" Padding="12,10" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="REJOINDRE UN HÔTE" FontFamily="Consolas" FontSize="10"
                                       FontWeight="Bold" Foreground="#6BAA88" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="ClientIpBox"
                                         Width="130" Height="28"
                                         Text="192.168.x.x"
                                         FontFamily="Consolas" FontSize="12"
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         Background="#0D1B14" Foreground="#A8D5BF"
                                         BorderBrush="#1D3A28" BorderThickness="1"
                                         Margin="0,0,6,0" />
                                <TextBox x:Name="ClientPortBox"
                                         Width="60" Height="28"
                                         Text="5757"
                                         FontFamily="Consolas" FontSize="12"
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         Background="#0D1B14" Foreground="#A8D5BF"
                                         BorderBrush="#1D3A28" BorderThickness="1"
                                         Margin="0,0,8,0" />
                                <Button x:Name="ConnectClientButton"
                                        Content="REJOINDRE"
                                        FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                        Padding="12,6"
                                        Background="#1A3A28" Foreground="#A8D5BF"
                                        BorderBrush="#2D5A40" BorderThickness="1"
                                        Cursor="Hand"
                                        Click="ConnectClientButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- DÉCONNECTER -->
                    <Button x:Name="DisconnectButton"
                            Content="❌ DÉCONNECTER"
                            FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                            Padding="12,6" VerticalAlignment="Bottom"
                            Background="#3D1010" Foreground="#FF6B6B"
                            BorderBrush="#C0392B" BorderThickness="1"
                            Cursor="Hand"
                            Visibility="Collapsed"
                            Click="DisconnectButton_Click" />
                </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

      </Grid>
    </ScrollViewer>

    <!-- ══ CONTENU TWITCH ══ -->
    <ScrollViewer x:Name="TwitchPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
      <StackPanel Margin="24,20,24,20" MaxWidth="640" HorizontalAlignment="Left">

        <TextBlock Text="INTÉGRATION TWITCH / NIGHTBOT"
                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource BrushTextPrimary}"
                   Margin="0,0,0,4" />
        <TextBlock Text="Met automatiquement à jour la commande Nightbot avec la liste des manches spéciales à chaque clic ENREGISTRER / +4 / +5."
                   FontFamily="Consolas" FontSize="12"
                   Foreground="{StaticResource BrushTextSecondary}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20" />

        <Rectangle Fill="{StaticResource BrushBorder}" Height="1" Margin="0,0,0,20" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="TwitchConnectButton"
                    Content="SE CONNECTER À TWITCH"
                    Style="{StaticResource ResetButtonStyle}"
                    Margin="0,0,10,0"
                    Click="TwitchConnectButton_Click" />
            <Button x:Name="TwitchDisconnectButton"
                    Content="DÉCONNECTER"
                    Style="{StaticResource ResetDangerButtonStyle}"
                    Click="TwitchDisconnectButton_Click" />
        </StackPanel>

        <TextBlock x:Name="TwitchStatusText"
                   Text="Non connecté."
                   FontFamily="Consolas" FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource BrushTextSecondary}"
                   Margin="0,0,0,20" />

        <TextBlock Text="RÉGLAGES"
                   Style="{StaticResource SectionLabelStyle}"
                   Margin="0,0,0,10" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Commande envoyée (met à jour Nightbot via !editcom) :"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource BrushTextSecondary}"
                       FontFamily="Consolas" FontSize="12"
                       Margin="0,0,10,0" />
            <TextBox x:Name="TwitchCommandTemplateBox"
                     Width="220" Height="30"
                     FontFamily="Consolas" FontSize="13"
                     VerticalContentAlignment="Center"
                     Background="{StaticResource BrushBgCard}"
                     Foreground="{StaticResource BrushTextPrimary}"
                     BorderBrush="{StaticResource BrushBorder}"
                     BorderThickness="1"
                     LostFocus="TwitchCommandTemplateBox_LostFocus" />
        </StackPanel>

        <CheckBox x:Name="TwitchAutoSendCheck"
                  Content="Envoyer automatiquement dans le chat au clic ENREGISTRER / +4 / +5"
                  Foreground="{StaticResource BrushTextSecondary}"
                  FontFamily="Consolas" FontSize="12"
                  Margin="0,0,0,16"
                  Checked="TwitchAutoSendCheck_Changed"
                  Unchecked="TwitchAutoSendCheck_Changed" />

        <Rectangle Fill="{StaticResource BrushBorder}" Height="1" Margin="0,0,0,16" />

        <TextBlock Text="RÉPONSE DIRECTE (alternative à Nightbot, à ne pas cumuler)"
                   Style="{StaticResource SectionLabelStyle}"
                   Margin="0,0,0,10" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Commande à écouter dans le chat :"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource BrushTextSecondary}"
                       FontFamily="Consolas" FontSize="12"
                       Margin="0,0,10,0" />
            <TextBox x:Name="TwitchListenCommandBox"
                     Width="120" Height="30"
                     FontFamily="Consolas" FontSize="13"
                     VerticalContentAlignment="Center"
                     Background="{StaticResource BrushBgCard}"
                     Foreground="{StaticResource BrushTextPrimary}"
                     BorderBrush="{StaticResource BrushBorder}"
                     BorderThickness="1"
                     LostFocus="TwitchListenCommandBox_LostFocus" />
        </StackPanel>

        <CheckBox x:Name="TwitchListenEnabledCheck"
                  Content="Répondre automatiquement quand un spectateur tape cette commande dans le chat"
                  Foreground="{StaticResource BrushTextSecondary}"
                  FontFamily="Consolas" FontSize="12"
                  Checked="TwitchListenEnabledCheck_Changed"
                  Unchecked="TwitchListenEnabledCheck_Changed" />

      </StackPanel>
    </ScrollViewer>

    </Grid>
</Window>
